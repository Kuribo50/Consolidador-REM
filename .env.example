# ==== App ====
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ==== Cola de consolidación ====
# direct: ejecuta consolidación en el request (modo estable local)
# redis: usa BullMQ + Redis con límites de concurrencia
CONSOLIDAR_QUEUE_MODE=direct

# Redis (solo requerido si CONSOLIDAR_QUEUE_MODE=redis)
REDIS_URL=redis://127.0.0.1:6379

# Límites de concurrencia (modo redis)
CONSOLIDAR_MAX_XLSX=4
CONSOLIDAR_MAX_CSV=8
CONSOLIDAR_MAX_TOTAL=8

# Timeout máximo de espera del job en cola + ejecución (ms)
CONSOLIDAR_JOB_WAIT_TIMEOUT_MS=900000
